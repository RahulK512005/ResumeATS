{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/frontend/dist/index.html" }
  ],
  "functions": {
    "api/auth.js": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 60
    },
    "api/resume.js": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
